{
  "manifest_version": 3,
  "name": "Usertour Lens",
  "version": "1.0.0",
  "description": "Point at anything on a page and instantly get its selector.",
  "permissions": ["activeTab", "scripting", "storage", "clipboardWrite"],
  "host_permissions": ["<all_urls>"],
  "commands": {
    "toggle-lens": {
      "suggested_key": {
        "default": "Alt+Shift+L",
        "mac": "Alt+Shift+L"
      },
      "description": "Toggle Lens element picker"
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "config.js",
        "core/state.js",
        "core/dom-utils.js",
        "core/selector.js",
        "core/formats.js",
        "ui/overlay.js",
        "ui/tooltip.js",
        "ui/panel.js",
        "ui/iframe-modal.js",
        "core/picker.js",
        "integrations/usertour.js",
        "integrations/iframe-bridge.js",
        "messaging/chrome-messages.js",
        "content.js"
      ],
      "css": [
        "styles/overlay.css",
        "styles/tooltip.css",
        "styles/panel.css",
        "styles/usertour.css",
        "styles/iframe-modal.css"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
